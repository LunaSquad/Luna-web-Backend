# URL de conexão com o MongoDB Atlas. 
# Substitua os campos entre < > pelas suas credenciais reais no seu arquivo .env local.
DB_URL=mongodb+srv://<usuario>:<senha>@<cluster>.<dominio>.mongodb.net/<database>?appName=<nome_do_app>

# Chave para o JWT (JSON Web Token)
JWT_SECRET=CHAVE_SECRETA_PARA_JWT_AQUI